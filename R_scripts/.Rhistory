```{r}
# Read the clean dataset
data <- readRDS(file = "../input/clean_data.rds")
View(data)
# Calculating mean bill length for different species and islands using dplyr
data %>%
group_by(species) %>%
summarize(mean_bill_length = round(mean(bill_length_mm, na.rm = TRUE), 2))
library(tidyverse)
library(tidyverse)
library(patchwork)
# Calculating mean bill length for different species and islands using dplyr
data %>%
group_by(species) %>%
summarize(mean_bill_length = round(mean(bill_length_mm, na.rm = TRUE), 2))
# Calculating mean bill depth for different species and islands using dplyr
data %>%
group_by(species) %>%
summarize(mean_bill_depth = round(mean(bill_depth_mm, na.rm = TRUE), 2))
